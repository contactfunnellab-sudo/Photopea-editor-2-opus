{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Photopea Primitive Editor Contract v2",
  "description": "Input/output contract for the Photopea primitive-based executor. Supports polygon_path (v1), ellipse, and box selection types. Fully deterministic — no LLM calls in execution.",

  "featureTransferInput": {
    "type": "object",
    "required": ["baseImageUrl", "referenceImageUrl", "photopeaOp", "selectionPrimitives"],
    "properties": {
      "baseImageUrl": {
        "type": "string",
        "format": "uri",
        "description": "URL of the base image (has the problem to fix)"
      },
      "referenceImageUrl": {
        "type": "string",
        "format": "uri",
        "description": "URL of the reference image (has the desired feature)"
      },
      "photopeaOp": {
        "type": "string",
        "enum": ["feature_transfer"],
        "description": "Operation type. v2 uses feature_transfer with selectionPrimitives."
      },
      "selectionPrimitives": {
        "type": "array",
        "minItems": 1,
        "description": "Array of selection primitives. Each processed separately (not merged). Each gets its own layer.",
        "items": {
          "type": "object",
          "required": ["type", "label", "source", "target"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["polygon_path", "ellipse", "box"],
              "description": "Selection type. V1 default is polygon_path. Future: bezier_path."
            },
            "label": {
              "type": "string",
              "description": "Feature label (e.g., 'left_eye', 'right_eye', 'lips')"
            },
            "source": {
              "type": "object",
              "required": ["points"],
              "properties": {
                "points": {
                  "type": "array",
                  "minItems": 3,
                  "items": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
                  "description": "Path points in reference image. [[x,y], ...] in pixel space."
                },
                "pointCount": {
                  "type": "integer",
                  "description": "Actual point count (runtime, not hardcoded)"
                }
              }
            },
            "target": {
              "type": "object",
              "required": ["points"],
              "properties": {
                "points": {
                  "type": "array",
                  "minItems": 3,
                  "items": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 },
                  "description": "Path points in base image. [[x,y], ...] in pixel space."
                },
                "pointCount": {
                  "type": "integer",
                  "description": "Actual point count (runtime, not hardcoded)"
                }
              }
            },
            "placementTransform": {
              "type": "object",
              "properties": {
                "translateX": { "type": "number", "default": 0, "description": "Horizontal translation (centroid delta)" },
                "translateY": { "type": "number", "default": 0, "description": "Vertical translation (centroid delta)" },
                "rotation": { "type": "number", "default": 0, "description": "Rotation in radians (from anchor pairs)" },
                "scale": { "type": "number", "default": 1.0, "description": "Uniform scale factor (from anchor pairs)" }
              }
            },
            "blend": {
              "type": "object",
              "properties": {
                "expandPx": { "type": "number", "minimum": 0, "default": 2 },
                "smoothPx": { "type": "number", "minimum": 0, "default": 1 },
                "featherRadius": { "type": "number", "minimum": 0, "maximum": 50, "default": 5, "description": "Source-side feather: softens the edge when copying from the reference image" },
                "maskFeatherRadius": { "type": "number", "minimum": 0, "maximum": 50, "default": 1, "description": "Target-shape mask feather: softens the boundary where the clipped donor meets the base face. Separate from source featherRadius." },
                "opacity": { "type": "number", "minimum": 0, "maximum": 100, "default": 100 }
              }
            }
          }
        }
      },
      "exportFormat": {
        "type": "string",
        "enum": ["png", "jpg", "webp"],
        "default": "png",
        "description": "Final export format (always produced)"
      },
      "debugExport": {
        "type": "boolean",
        "default": true,
        "description": "If true, also export PSD with layers for debugging"
      }
    }
  },

  "featureTransferOutput": {
    "type": "object",
    "properties": {
      "success": { "type": "boolean" },
      "imageBase64": { "type": "string", "description": "Base64-encoded final image (png)" },
      "psdBase64": { "type": ["string", "null"], "description": "Base64-encoded PSD (if debugExport=true)" },
      "logs": { "type": "array", "items": { "type": "string" } },
      "durationMs": { "type": "number" },
      "error": { "type": "string" }
    }
  },

  "primitivesInput": {
    "type": "object",
    "required": ["baseImageUrl", "referenceImageUrl", "features"],
    "properties": {
      "baseImageUrl": { "type": "string", "format": "uri" },
      "referenceImageUrl": { "type": "string", "format": "uri" },
      "features": {
        "type": "array",
        "items": { "type": "string", "enum": ["left_eye", "right_eye", "lips", "left_eyebrow", "right_eyebrow", "face_oval"] }
      },
      "outputMode": { "type": "string", "enum": ["polygon_path"], "default": "polygon_path" },
      "targetFaceHint": {
        "type": ["string", "integer"],
        "description": "'largest', 'leftmost', 'rightmost', or integer face index",
        "default": "largest"
      },
      "includeRawLandmarks": { "type": "boolean", "default": false }
    }
  },

  "primitivesOutput": {
    "type": "object",
    "properties": {
      "success": { "type": "boolean" },
      "primitiveType": { "type": "string" },
      "imageMeta": {
        "type": "object",
        "properties": {
          "base": { "type": "object", "properties": { "width": { "type": "integer" }, "height": { "type": "integer" } } },
          "reference": { "type": "object", "properties": { "width": { "type": "integer" }, "height": { "type": "integer" } } }
        }
      },
      "detections": {
        "type": "object",
        "properties": {
          "baseFaces": { "type": "integer" },
          "referenceFaces": { "type": "integer" },
          "baseTotalLandmarks": { "type": "integer", "description": "Actual runtime count (not hardcoded)" },
          "referenceTotalLandmarks": { "type": "integer", "description": "Actual runtime count (not hardcoded)" },
          "chosenBaseFaceIndex": { "type": "integer" },
          "chosenReferenceFaceIndex": { "type": "integer" }
        }
      },
      "features": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "base": {
              "type": "object",
              "properties": {
                "rawPointCount": { "type": "integer" },
                "pixelPoints": { "type": "array" },
                "pathPoints": { "type": "array" }
              }
            },
            "reference": {
              "type": "object",
              "properties": {
                "rawPointCount": { "type": "integer" },
                "pixelPoints": { "type": "array" },
                "pathPoints": { "type": "array" }
              }
            },
            "placementTransform": {
              "type": "object",
              "properties": {
                "translateX": { "type": "number" },
                "translateY": { "type": "number" },
                "rotation": { "type": "number" },
                "scale": { "type": "number" }
              }
            },
            "recommendedBlend": {
              "type": "object",
              "properties": {
                "expandPx": { "type": "number" },
                "smoothPx": { "type": "number" },
                "featherRadius": { "type": "number" }
              }
            }
          }
        }
      }
    }
  },

  "futureTypes": {
    "bezier_path": "Not yet implemented. Will support true Pen-style bezier handles.",
    "pose_path": "Architecture stub for pose_landmarks primitive.",
    "mask": "Architecture stub for segment_mask primitive."
  },

  "executionModel": {
    "description": "Fully deterministic. No LLM calls, no AI generation. CPU execution via tfjs-node.",
    "steps": [
      "1. Load base image into Photopea as document[0]",
      "2. Load reference image into Photopea as document[1]",
      "3. Copy reference and paste as layer in base document, scale to match",
      "4. Close reference document",
      "5. For EACH selectionPrimitive separately:",
      "   a. Activate reference layer",
      "   b. doc.selection.select(primitive.source.points) — polygon path",
      "   c. doc.selection.feather(blend.featherRadius) — source-side feather",
      "   d. Copy and paste as new layer",
      "   e. Name layer 'Feature: {label}'",
      "   f. If target.points exist: non-uniform resize(scaleXPct, scaleYPct) from source/target bbox ratios; else uniform scale",
      "   g. Apply rotation and translation from placementTransform",
      "   h. If target.points exist: select target polygon, feather(maskFeatherRadius), invert, cut — clips donor to target eye shape",
      "   i. Deselect",
      "6. Hide reference layer (preserved in PSD for debug)",
      "7. Export final png",
      "8. Export PSD if debugExport=true"
    ]
  }
}
